# Production build config for the SPA (loaded automatically by `vite build`).
# The SPA calls the backend directly — NOT through the SWA /api proxy, whose 45 s
# request limit would cut off long agent runs (see docs/DECISIONS.md D02).
# Backend = the Agent Framework AG-UI host on Azure Container Apps (Consumption).
# Not a secret: this is a public endpoint. CI may override via the VITE_API_BASE_URL repo variable.
VITE_API_BASE_URL=https://ca-fabops-ui.redbush-d7ef9598.northeurope.azurecontainerapps.io
